#!/usr/bin/env bash
# Wrapper for the mapping-based DJ counting pipeline.
#
# Works in two layouts:
#   1. Repo clone / environment.yml install:
#        <repo>/bin/djcounter-map  ->  <repo>/scripts/calCounts.sh
#   2. Bioconda install:
#        $CONDA_PREFIX/bin/djcounter-map
#          ->  $CONDA_PREFIX/share/djcounter/scripts/calCounts.sh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PREFIX_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if   [[ -s "$PREFIX_DIR/scripts/calCounts.sh" ]]; then
    TARGET="$PREFIX_DIR/scripts/calCounts.sh"
elif [[ -s "$PREFIX_DIR/share/djcounter/scripts/calCounts.sh" ]]; then
    TARGET="$PREFIX_DIR/share/djcounter/scripts/calCounts.sh"
else
    echo "djcounter-map: cannot locate calCounts.sh relative to $SCRIPT_DIR" >&2
    exit 1
fi

exec "$TARGET" "$@"
